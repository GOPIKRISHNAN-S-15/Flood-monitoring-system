{
  "name": "iot-flood-monitoring-system",
  "version": "1.0.0",
  "description": "Smart IoT Flood Monitoring and Automated Flood Gate System - Complete full-stack web application with NodeMCU integration for real-time flood monitoring and automated gate control",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "echo \"No build process required for this project\"",
    "lint": "eslint server/**/*.js",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "db:reset": "rm -f server/database.sqlite && node server/server.js",
    "health": "curl -s http://localhost:3000/api/health || echo \"Server not responding\"",
    "install-global": "npm install -g nodemon pm2",
    "production": "NODE_ENV=production pm2 start ecosystem.config.js"
  },
  "keywords": [
    "iot",
    "flood-monitoring",
    "nodemcu",
    "esp8266",
    "sensor",
    "automation",
    "web-dashboard",
    "real-time",
    "nodejs",
    "express",
    "sqlite",
    "bootstrap",
    "chartjs",
    "servo-control",
    "ultrasonic-sensor",
    "smart-city",
    "disaster-management"
  ],
  "author": {
    "name": "Team Pixel Hunters",
    "email": "pixelhunters@mkce.ac.in",
    "url": "https://github.com/pixel-hunters"
  },
  "contributors": [
    {
      "name": "Gopikrishnan.S",
      "email": "gopikrishnan@mkce.ac.in",
      "role": "Lead Developer & Project Coordinator"
    },
    {
      "name": "Deepak Kumar.M",
      "email": "deepakkumar@mkce.ac.in",
      "role": "Hardware Specialist & IoT Engineer"
    },
    {
      "name": "Jeeva.K",
      "email": "jeeva@mkce.ac.in",
      "role": "Frontend Developer & UI/UX Designer"
    },
    {
      "name": "Mithun.S",
      "email": "mithun@mkce.ac.in",
      "role": "Backend Developer & Database Architect"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixel-hunters/iot-flood-monitoring.git"
  },
  "bugs": {
    "url": "https://github.com/pixel-hunters/iot-flood-monitoring/issues"
  },
  "homepage": "https://github.com/pixel-hunters/iot-flood-monitoring#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "optionalDependencies": {
    "pm2": "^5.3.0"
  },
  "nodemonConfig": {
    "watch": [
      "server/"
    ],
    "ext": "js,json",
    "ignore": [
      "server/database.sqlite",
      "server/logs/",
      "node_modules/"
    ],
    "env": {
      "NODE_ENV": "development"
    }
  },
  "funding": {
    "type": "institutional",
